							"mode": "raw",
							"raw": "{\n  \"aggregations\": [\n    {\n      \"function\": \"COUNT\",\n      \"field\": \"*\",\n      \"alias\": \"total_employees\"\n    }\n  ],\n  \"filters\": [\n    {\n      \"field\": \"department\",\n      \"operator\": \"=\",\n      \"value\": \"Engineering\"\n    }\n  ]\n}"
