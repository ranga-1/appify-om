				{
					"name": "Average Salary by Department",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-User-ID",
								"value": "{{user_id}}",
								"type": "text"
							},
							{
								"key": "X-Tenant-ID",
								"value": "{{tenant_id}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"aggregations\": [\n    {\n      \"function\": \"AVG\",\n      \"field\": \"salary\",\n      \"alias\": \"avg_salary\"\n    },\n    {\n      \"function\": \"COUNT\",\n      \"field\": \"*\",\n      \"alias\": \"employee_count\"\n    }\n  ],\n  \"group_by\": [\"department\"],\n  \"order_by\": [\"avg_salary DESC\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/data/{{object_name}}/aggregate",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "data", "{{object_name}}", "aggregate"]
						}
